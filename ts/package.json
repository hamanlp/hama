{
  "name": "hama-js",
  "version": "1.3.9",
  "description": "ONNX-powered G2P + phoneme-ASR inference for Node, Bun, and browsers.",
  "homepage": "https://hamalnp.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamanlp/hama.git",
    "directory": "ts"
  },
  "bugs": {
    "url": "https://github.com/hamanlp/hama/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/node/index.js",
  "module": "dist/node/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/node/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./g2p": {
      "import": "./dist/node/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./asr": {
      "import": "./dist/node/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/browser.js",
      "types": "./dist/types/browser.d.ts"
    },
    "./g2p/browser": {
      "import": "./dist/browser/browser.js",
      "types": "./dist/types/browser.d.ts"
    },
    "./asr/browser": {
      "import": "./dist/browser/browser.js",
      "types": "./dist/types/browser.d.ts"
    },
    "./jamo": {
      "import": "./dist/node/jamo.js",
      "types": "./dist/types/jamo.d.ts"
    },
    "./tokenizer": {
      "import": "./dist/node/tokenizer.js",
      "types": "./dist/types/tokenizer.d.ts"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/hamanlp"
  },
  "typesVersions": {
    "*": {
      "g2p": [
        "dist/types/index.d.ts"
      ],
      "asr": [
        "dist/types/index.d.ts"
      ],
      "g2p/browser": [
        "dist/types/browser.d.ts"
      ],
      "asr/browser": [
        "dist/types/browser.d.ts"
      ],
      "browser": [
        "dist/types/browser.d.ts"
      ],
      "jamo": [
        "dist/types/jamo.d.ts"
      ],
      "tokenizer": [
        "dist/types/tokenizer.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "bun run build:node && bun run build:browser",
    "build:node": "tsc -p tsconfig.node.json && rm -rf dist/node/assets && mkdir -p dist/node/assets && cp -R src/assets/. dist/node/assets",
    "build:browser": "tsc -p tsconfig.browser.json && rm -rf dist/browser/assets && mkdir -p dist/browser/assets && cp -R src/assets/. dist/browser/assets",
    "test": "bun test",
    "validate:model": "bun run scripts/validate-model.ts",
    "validate:model:split": "bun run scripts/validate-split-model.ts",
    "validate:asr": "bun run scripts/validate-asr-model.ts",
    "validate:browser": "bun run scripts/validate-browser-model.ts",
    "validate:browser:asr": "bun run scripts/validate-browser-asr-model.ts",
    "live:asr:silero": "bun run scripts/live-asr-silero.ts"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "asr",
    "g2p",
    "onnx",
    "bun",
    "onnxruntime"
  ],
  "author": "Seongmin Park",
  "license": "Apache-2.0",
  "devDependencies": {
    "@ricky0123/vad-node": "^0.0.3",
    "@types/node": "^20.19.25",
    "bun-types": "^1.3.3",
    "node-record-lpcm16": "^1.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "onnxruntime-node": "^1.23.2",
    "onnxruntime-web": "^1.23.2"
  },
  "packageManager": "bun@1.1.0"
}
